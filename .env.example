# Copy this file to .env.local for local development
# Set the same vars in Vercel dashboard → Settings → Environment Variables

# ── Instagram Basic Display API ────────────────────────
# Get at: https://developers.facebook.com/apps/ → Instagram Basic Display
INSTAGRAM_ACCESS_TOKEN=

# ── Google Places API ──────────────────────────────────
# Enable "Places API" at: https://console.cloud.google.com/
GOOGLE_PLACES_API_KEY=
# Find your Place ID at: https://developers.google.com/maps/documentation/javascript/examples/places-placeid-finder
GOOGLE_PLACE_ID=

# ── Contact Form (Resend) ──────────────────────────────
# Free account at: https://resend.com (100 emails/day)
RESEND_API_KEY=
CONTACT_TO_EMAIL=info@kiliansmarthomes.com
