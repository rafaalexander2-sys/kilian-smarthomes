# Copy this file to .env.local for local development
# Set the same vars in Vercel dashboard → Settings → Environment Variables

# ── Instagram Basic Display API ────────────────────────
# Get at: https://developers.facebook.com/apps/ → Instagram Basic Display
INSTAGRAM_ACCESS_TOKEN=

# ── Contact Form ───────────────────────────────────────
# Uses Web3Forms (client-side, no env var needed).
# Get a free access key at https://web3forms.com and paste it into
# the hidden "access_key" input in index.html (contact form).
